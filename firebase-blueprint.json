{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and credentials",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "password": { "type": "string", "description": "Hashed password" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["name", "email", "password", "role"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "Cafe menu item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "category", "image", "description"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Contact form message",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/menu/{itemId}": {
      "schema": "MenuItem",
      "description": "Menu items"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Contact messages"
    }
  }
}
